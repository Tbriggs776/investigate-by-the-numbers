# Required secrets for Investigate by the Numbers.
# These are set as Supabase Edge Function secrets — NEVER committed with values.
#
# Set via CLI:
#   supabase secrets set SAM_API_KEY=your_key --project-ref ipdimgygevkwzjokcmvj
# or in the Dashboard:
#   Project Settings -> Edge Functions -> Secrets

# SAM.gov entity API — used in Phase 2 (entity resolution / enrichment).
SAM_API_KEY=

# USAspending requires NO key (public API). Phase 1 ingestion needs nothing here.

# ────────────────────────────────────────────────────────────────────────────
# Phase 5 — Review Dashboard (Vite frontend). Copy to .env.local with values.
# These are PUBLIC: the publishable key is safe to ship to the browser. Data is
# protected by Row-Level Security — anon reads nothing, only authenticated
# reviewers read. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://ipdimgygevkwzjokcmvj.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...
